{
  "name": "illusiard/yii2-rabbitmq",
  "description": "Yii2 RabbitMQ extension with lazy connection and interfaces for future AMQP implementation.",
  "type": "yii2-extension",
  "license": "BSD-3-Clause",
  "require": {
    "php": ">=8.1",
    "php-amqplib/php-amqplib": "^3.5",
    "yiisoft/yii2": "^2.0.47",
    "ext-pcntl": "*",
    "ext-ctype": "*"
  },
  "autoload": {
    "psr-4": {
      "illusiard\\rabbitmq\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "illusiard\\rabbitmq\\tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "ext-posix": "*"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "minimum-stability": "stable",
  "keywords": [
    "yii2",
    "rabbitmq",
    "amqp",
    "extension"
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "scripts": {
    "test": [
      "@php vendor/bin/phpunit"
    ]
  }
}
