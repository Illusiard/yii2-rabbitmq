{
  "name": "illusiard/yii2-rabbitmq",
  "description": "Yii2 RabbitMQ extension with lazy AMQP connections, publisher confirms, topology tools, consumers, retries, DLQ helpers, and RPC.",
  "type": "yii2-extension",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/Illusiard/yii2-rabbitmq",
  "authors": [
    {
      "name": "Illusiard"
    }
  ],
  "support": {
    "issues": "https://github.com/Illusiard/yii2-rabbitmq/issues",
    "source": "https://github.com/Illusiard/yii2-rabbitmq"
  },
  "require": {
    "php": ">=8.1",
    "php-amqplib/php-amqplib": "^3.5",
    "phpseclib/phpseclib": "^3.0.52",
    "yiisoft/yii2": "^2.0.55",
    "ext-ctype": "*",
    "ext-pcntl": "*"
  },
  "autoload": {
    "psr-4": {
      "illusiard\\rabbitmq\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "illusiard\\rabbitmq\\tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5.62",
    "ext-posix": "*"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "minimum-stability": "stable",
  "keywords": [
    "yii2",
    "rabbitmq",
    "amqp",
    "extension"
  ],
  "suggest": {
  },
  "extra": {
    "bootstrap": "illusiard\\rabbitmq\\Bootstrap"
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "scripts": {
    "test": [
      "@php vendor/bin/phpunit --bootstrap tests/bootstrap.php tests --exclude-group integration"
    ]
  }
}
